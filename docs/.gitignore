# === Python 暫存與快取 ===
__pycache__/
*.py[cod]
*$py.class

# === 打包 / 發佈產物 ===
# setuptools build 出來的東西，這個專案有 pyproject.toml 用 setuptools
# 打包時一定會產生這些資料夾，之前沒排除的話很容易誤 commit 進去
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# === 虛擬環境 ===
# 原本完全沒排除，如果曾經在專案資料夾內建過 venv，很可能整包被追蹤了
.venv/
venv/
env/
ENV/

# === 測試 / 覆蓋率 ===
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# === IDE / 編輯器 ===
.vscode/
.idea/
*.swp
*.swo

# === 環境變數與私密設定 ===
# 避免不小心把 API key、密碼等機密資訊推上 GitHub
.env
.env.*
*.local

# === 打包與壓縮檔 ===
*.zip
*.tar.gz

# === 系統檔案 ===
.DS_Store
Thumbs.db

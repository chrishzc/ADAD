{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adad.dev/schema/task_schema.json",
  "title": "ADAD Frozen Coding Task Snapshot",
  "type": "object",
  "oneOf": [
    {
      "properties": { "schema_version": { "enum": [2] } }
    },
    {
      "properties": {
        "schema_version": { "enum": [3] },
        "spec": {
          "properties": {
            "target_node": {
              "required": [
                "description",
                "map_file",
                "dependencies",
                "preferred_pattern",
                "decisions",
                "complexity",
                "algorithm",
                "idempotency",
                "retry_budget",
                "required_context",
                "forbidden_context",
                "context_priority",
                "non_goals"
              ]
            }
          }
        }
      }
    }
  ],
  "required": ["schema_version", "task_id", "node_name", "exported_at", "system_map_version", "source_hash", "status", "source_lock", "rollback", "history", "spec"],
  "properties": {
    "schema_version": { "enum": [2, 3] },
    "task_id": { "type": "string", "minLength": 1 },
    "node_name": { "type": "string", "minLength": 1 },
    "exported_at": { "type": "string", "minLength": 1 },
    "system_map_version": { "type": "integer", "minimum": 1 },
    "source_hash": { "type": "string", "minLength": 1 },
    "status": { "enum": ["assigned", "in_progress", "submitted", "approved", "rejected", "blocked"] },
    "block_reason": { "type": "string" },
    "source_lock": {
      "type": "object",
      "required": ["source_path", "node_name", "task_id", "acquired_at"],
      "properties": {
        "source_path": { "type": "string", "minLength": 1 },
        "node_name": { "type": "string", "minLength": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "acquired_at": { "type": "string", "minLength": 1 }
      }
    },
    "rollback": {
      "type": "object",
      "required": ["strategy", "source_path", "baseline_file_hash", "instruction"],
      "properties": {
        "strategy": { "const": "preserve_diff" },
        "source_path": { "type": "string" },
        "baseline_file_hash": { "type": ["string", "null"] },
        "rejected_file_hash": { "type": ["string", "null"] },
        "source_changed_since_issue": { "type": "boolean" },
        "instruction": { "type": "string", "minLength": 1 }
      }
    },
    "history": { "type": "array", "items": { "type": "object" } },
    "spec": {
      "type": "object",
      "required": ["target_node", "dependency_interfaces"],
      "properties": {
        "target_node": {
          "type": "object",
          "required": ["name", "type", "state", "source", "input", "output", "exceptions", "invariants", "verification", "observability"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "type": { "type": "string", "minLength": 1 },
            "state": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 1 },
            "map_file": { "type": "string", "minLength": 1 },
            "dependencies": { "type": "array", "items": { "type": "string" } },
            "input": { "type": "object" },
            "output": { "type": "object" },
            "exceptions": { "type": "array" },
            "invariants": { "type": "array" },
            "preferred_pattern": { "type": "string", "minLength": 1 },
            "decisions": { "type": "array", "items": { "type": "string" } },
            "verification": { "type": "array" },
            "observability": { "type": "object" },
            "complexity": { "enum": ["low", "medium", "high"] },
            "algorithm": { "type": "array", "items": { "type": "string" } },
            "idempotency": { "type": "object" },
            "retry_budget": { "type": "integer" },
            "required_context": { "type": "array" },
            "forbidden_context": { "type": "array" },
            "context_priority": { "type": "object" },
            "non_goals": { "type": "array", "items": { "type": "string" } }
          }
        },
        "dependency_interfaces": { "type": "object" }
      }
    }
  }
}
